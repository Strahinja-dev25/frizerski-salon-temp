# ============================================================================
# Environment Variables — Frizerski Salon Template
# ============================================================================
# Kopirajte ovaj fajl u .env i popunite vrednosti.
# .env NIKADA ne sme biti commitovan u git!
# ============================================================================

# --- Baza podataka (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# --- Clerk Autentifikacija ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect URL-ovi
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- Cron Job zaštita ---
CRON_SECRET="vas-tajni-kljuc-ovde"

# --- Sajt info (opciono, za SEO) ---
NEXT_PUBLIC_SITE_URL="https://vas-domen.vercel.app"
